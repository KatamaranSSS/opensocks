SSSERVER_PUBLIC_HOST=109.71.246.216
SSSERVER_IMAGE=ghcr.io/shadowsocks/ssserver-rust:latest
SSSERVER_PORT=8389
SSSERVER_MODE=tcp_and_udp
SSSERVER_METHOD=chacha20-ietf-poly1305
