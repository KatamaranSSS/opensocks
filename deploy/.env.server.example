SSSERVER_PUBLIC_HOST=109.71.246.216
SSSERVER_IMAGE=ghcr.io/shadowsocks/ssserver-rust:latest
SSSERVER_PORT=8389
SSSERVER_MODE=tcp_and_udp
SSSERVER_METHOD=chacha20-ietf-poly1305
SSSERVER_PASSWORD=change-me
SSSERVER_TIMEOUT=60

# Obfuscation test mode (SIP003 plugin via v2ray-plugin)
# When true, deploy script switches image/command and generates plugin config.
SSSERVER_OBFS_ENABLED=false
SSSERVER_PLUGIN=v2ray-plugin
SSSERVER_OBFS_MODE=websocket
SSSERVER_OBFS_PATH=/ws
SSSERVER_OBFS_HOST=

# Isolated SS2022 test instance (separate container and port)
SS2022_IMAGE=ghcr.io/shadowsocks/ssserver-rust:latest
SS2022_PUBLIC_HOST=109.71.246.216
SS2022_PORT=8391
SS2022_MODE=tcp_and_udp
SS2022_METHOD=2022-blake3-aes-128-gcm
# Example only. Generate real key via: scripts/generate_ss2022_key.sh
SS2022_PASSWORD_BASE64=MDEyMzQ1Njc4OWFiY2RlZg==
SS2022_TIMEOUT=60
