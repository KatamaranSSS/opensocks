[Unit]
Description=OpenSocks Telegram Config Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/opensocks
EnvironmentFile=/opt/opensocks/bot/.env
ExecStart=/opt/opensocks/.venv/bin/python /opt/opensocks/bot/config_bot.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
